---
import { SkiCycleRunConfig } from "../skicyclerun.config";
import { isDebugEnabled } from "../utils/debugFlag";
// ImageMetadata is no longer exported from astro in newer versions
// import type { ImageMetadata } from "astro";
export function getRndValue(images: any) {
  const randomIndex = Math.floor(Math.random() * images.length);
  return images[randomIndex];
}

export async function getLocalImages() {
  const imageObject = import.meta.glob<{ default: ImageMetadata }>(
    "/src/assets/images/*.{jpeg,jpg,png,gif,svg}",
  );
  const imageKeys = Object.keys(imageObject);
  return imageKeys;
}

export async function getImgMeta(imgPath: string) {
  if (isDebugEnabled()) console.log("getImgMeta: ", imgPath);
  return imgPath;
}

export async function getAlbumPhotos(
  album: any,
  loraStyle: string = "random",
): Promise<any[]> {
  try {
    let photos: any[] = [];

    const parsePhotoArray = (payload: any): any[] => {
      if (Array.isArray(payload)) return payload;
      if (payload && Array.isArray(payload.photos)) return payload.photos;
      if (payload && Array.isArray(payload.data)) return payload.data;
      if (payload && Array.isArray(payload.items)) return payload.items;
      return [];
    };

    const buildAlbumCandidates = (rawAlbum: string): string[] => {
      const base = `${rawAlbum || ""}`.trim();
      if (!base) return [];

      const camelToDash = base.replace(/([a-z0-9])([A-Z])/g, "$1-$2");
      const dashToCamel = base.replace(/-([a-zA-Z0-9])/g, (_, c) =>
        `${c}`.toUpperCase(),
      );

      const candidates = [
        base,
        base.toLowerCase(),
        base.replace(/\s+/g, "-"),
        base.replace(/\s+/g, ""),
        camelToDash,
        camelToDash.toLowerCase(),
        dashToCamel,
        dashToCamel.toLowerCase(),
      ];

      return [...new Set(candidates.filter(Boolean))];
    };

    // Use local images only if explicitly requested or during SSG build
    if (album === "local") {
      const imagePaths = await getLocalImages();
      const imageModules = import.meta.glob<{ default: ImageMetadata }>(
        "/src/assets/images/*.{jpeg,jpg,png,gif,svg}",
      );

      photos = await Promise.all(
        imagePaths.map(async (path: string, i: number) => {
          const mod = imageModules[path];
          const img = mod ? await mod() : null;
          return {
            src: img?.default?.src ?? undefined, // ✅ Use the actual image path
            altText: `Photo ${i + 1}`,
            sourceType: "local",
          };
        }),
      );
    } else {
      // Development mode - try API call with fallback to local
      try {
        const baseUrl =
          import.meta.env.PUBLIC_SKICYCLERUN_API ||
          "https://api.skicyclerun.com/v2/";
        const loraParam =
          loraStyle === "random" ? "" : `&loraStyle=${loraStyle}`;
        const candidates = buildAlbumCandidates(`${album}`);
        let apiPayload: any = null;
        let usedAlbum = "";

        for (const candidate of candidates) {
          const photoURL = `${baseUrl}getphotosrandom?bucketName=skicyclerun.lib&albumPath=albums/${encodeURIComponent(candidate)}/&numPhotos=${SkiCycleRunConfig.photoApi.buildTimePhotos}${loraParam}`;
          if (isDebugEnabled()) {
            console.log(
              `[Library:getAlbumPhotos] Initial photo fetch URL: ${photoURL}`,
            );
          }
          const res = await fetch(photoURL);
          const data = await res.json();
          const parsed = parsePhotoArray(data);

          if (parsed.length > 0) {
            apiPayload = parsed;
            usedAlbum = candidate;
            break;
          }

          // Exit early on explicit server errors rather than probing more variants.
          if ((data as any)?.message === "Internal server error") {
            apiPayload = null;
            break;
          }
        }

        if (Array.isArray(apiPayload) && apiPayload.length > 0) {
          photos = apiPayload.map((p: any, i: number) => {
            const src = typeof p === "string" ? p : p?.src;
            return {
              src,
              altText:
                (typeof p === "object" && (p?.altText || p?.alt)) ||
                `Photo ${i + 1}`,
              sourceType: "remote",
            };
          });

          if (usedAlbum && usedAlbum !== `${album}`) {
            console.warn(
              `ℹ️ Album "${album}" resolved using variant "${usedAlbum}"`,
            );
          }
        } else {
          console.warn(
            `⚠️ No remote photos found for album "${album}", falling back to local images`,
          );
          photos = await getAlbumPhotos("local");
        }
      } catch (apiError) {
        const loraParam =
          loraStyle === "random" ? "" : `&loraStyle=${loraStyle}`;
        console.warn("Photo API failed, falling back to local images");
        if (isDebugEnabled()) {
          console.warn(
            "URL:",
            `${import.meta.env.PUBLIC_SKICYCLERUN_API || "https://api.skicyclerun.com/v2/"}getphotosrandom?bucketName=skicyclerun.lib&albumPath=albums/${album}/&numPhotos=${SkiCycleRunConfig.photoApi.buildTimePhotos}${loraParam}`,
          );
          console.warn(
            "Error type:",
            apiError instanceof Error ? apiError.name : typeof apiError,
          );
          console.warn(
            "Error message:",
            apiError instanceof Error ? apiError.message : String(apiError),
          );
          console.warn("Album:", album);
          console.warn("LoRA Style:", loraStyle);
        }
        photos = await getAlbumPhotos("local");
      }
    }

    return photos;
  } catch (error) {
    if (isDebugEnabled()) console.log("ERROR:getAlbumPhotos", error);
    // Final fallback to empty array to prevent build failures
    return [];
  }
}

export function getRandomImage(
  imagesObject: Record<string, () => Promise<{ default: ImageMetadata }>>,
) {
  const imagePaths = Object.keys(imagesObject);
  const randomIndex = Math.floor(Math.random() * imagePaths.length);
  const randomImagePath = imagePaths[randomIndex];

  return randomImagePath;
}

export function findKeyWithValue(
  searchString: string,
  obj: Record<string, any>,
) {
  for (const key in obj) {
    if (isDebugEnabled()) console.log("findKeyWithValue: key == ", key);
    if (key.includes(searchString)) {
      return { key, value: obj[key] };
    }
  }
  return null;
}

