---
const { photos = [], frontmatter = {} } = Astro.props;
const first = photos && photos.length ? photos[0] : null;
---

<div class="mdx-hero">
  {first ? (
  <figure class="hero-figure" data-photos-json>
      <!-- Embed the photo list using Astro-recommended JSON block, scoped near usage -->
      <script
        type="application/json"
        id="hero-photos"
        set:html={JSON.stringify(photos).replace(/</g, '\\u003c')}
      />

      <img
        src={first.src}
        alt={first.alt ?? first.altText ?? frontmatter.title ?? "Hero image"}
        loading="lazy"
        decoding="async"
        data-current-index={0}
        class="hero-image"
        draggable="false"
        style="cursor: pointer;"
      />
      <!-- Photo counter pill -->
      <div id="hero-counter" class="hero-counter-pill">
        {photos.length > 1 ? `1 / ${photos.length}` : ''}
      </div>
      {frontmatter.title && (
        <figcaption class="hero-caption text-sm text-skin-muted">
          {frontmatter.title}
        </figcaption>
      )}

        <script is:inline>
(() => {
          const debug = window.debugLog
            ? (...args) => window.debugLog("ui", ...args)
            : () => {};

  function init() {
            debug("[Hero] init() called");
    const container = document.querySelector("figure[data-photos-json]");
    if (!container) {
              debug("[Hero] No container found");
      return;
    }
            debug("[Hero] Container found");
    if (container.dataset.heroInitialized === "1") {
              debug("[Hero] Already initialized");
      return;
    }

    const img = container.querySelector("img");
    if (!img) {
              debug("[Hero] No img found");
      return;
    }
            debug("[Hero] Img found");

    let photos = [];
    let dataEl;
    try {
      dataEl = container.querySelector('script[type="application/json"]#hero-photos') || document.getElementById('hero-photos');
      if (dataEl) {
        const raw = (dataEl.textContent || '').trim();
        debug("[Hero] Raw JSON text:", raw);
        photos = JSON.parse(raw);
        debug("[Hero] Photos parsed:", photos.length, "items");
      } else {
        debug("[Hero] No data element found");
      }
    } catch (e) {
      debug("[Hero] JSON parse error:", e);
      debug("[Hero] Error details - raw text was:", dataEl ? (dataEl.textContent || '').trim() : 'no element');
    }

    if (!Array.isArray(photos) || photos.length === 0) {
      debug("[Hero] No valid photos array");
      return;
    }

    // Ensure index is tracked on the <img>
    if (!img.dataset.currentIndex) img.dataset.currentIndex = "0";
    debug("[Hero] Initial index set to:", img.dataset.currentIndex);

    const counterEl = container.querySelector('#hero-counter');
    function updateHeroCounter(idx) {
      if (counterEl && photos.length > 1) {
        counterEl.textContent = `${idx + 1} / ${photos.length}`;
      }
    }

    img.addEventListener("click", () => {
      let idx = Number(img.dataset.currentIndex) || 0;
      idx = (idx + 1) % photos.length;
      img.dataset.currentIndex = String(idx);
      const p = photos[idx];
      if (p) {
        // Bounce-scale feedback then swap src
        img.style.transform = 'scale(0.93)';
        img.style.opacity = '0.7';
        setTimeout(() => {
          img.src = p.src;
          img.alt = p.alt || p.altText || "Hero image";
          img.style.transform = '';
          img.style.opacity = '';
          updateHeroCounter(idx);
        }, 120);
      }
    });

    container.dataset.heroInitialized = "1";
    debug("[Hero] Initialization complete");
  }

  debug("[Hero] Script loaded, readyState:", document.readyState);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
    debug("[Hero] Added DOMContentLoaded listener");
  } else {
    init();
  }

  document.addEventListener("astro:after-swap", () => {
    debug("[Hero] astro:after-swap detected");
    init();
  });
})();
</script>
    </figure>
  ) : (
    <div>No photos available</div>
  )}
</div>

<style>
  .mdx-hero {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    margin: 0;
    padding: 0;
  }
  .hero-figure {
    position: relative;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    background: radial-gradient(
      140% 150% at 10% 8%,
      rgba(var(--color-accent), 0.16),
      rgba(var(--color-fill), 0.35) 40%,
      rgba(var(--color-fill), 0.9) 100%
    );
    overflow: hidden;
  }
  .hero-figure img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    background: transparent;
    transition:
      transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.26s ease,
      filter 0.26s ease;
  }

  .hero-counter-pill {
    position: absolute;
    right: 0.8rem;
    top: 0.8rem;
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.72rem;
    letter-spacing: 0.01em;
    font-weight: 600;
    background: rgba(0, 0, 0, 0.34);
    padding: 0.24rem 0.55rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    pointer-events: none;
    backdrop-filter: blur(10px) saturate(130%);
    -webkit-backdrop-filter: blur(10px) saturate(130%);
    white-space: nowrap;
    z-index: 3;
  }

  .hero-caption {
    position: absolute;
    top: 0.8rem;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    padding: 0.32rem 0.7rem;
    border-radius: 9999px;
    border: 1px solid rgba(var(--color-border), 0.42);
    background: rgba(var(--color-card), 0.6);
    color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px) saturate(126%);
    -webkit-backdrop-filter: blur(10px) saturate(126%);
    pointer-events: none;
    white-space: nowrap;
    max-width: calc(100% - 7.5rem);
    overflow: hidden;
    text-overflow: ellipsis;
    z-index: 3;
  }
  
  .hero-image:hover {
    transform: scale(1.02);
    filter: brightness(1.05) saturate(1.03);
  }
  
  .hero-image:active {
    transform: scale(0.985);
  }

  @media (max-width: 768px) {
    .hero-counter-pill {
      right: 0.55rem;
      top: 0.55rem;
    }

    .hero-caption {
      top: 0.55rem;
      max-width: calc(100% - 6.25rem);
      text-overflow: ellipsis;
      overflow: hidden;
    }
  }
</style>