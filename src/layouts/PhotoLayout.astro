---
import { getAlbumPhotos } from "@components/Library.astro";
import { SkiCycleRunConfig } from "../skicyclerun.config";
import MDXCarousel3 from "./MDXCarousel3.astro";
import MDXHeroView from "./MDXHeroView.astro";
import MDXGalleryView from "./MDXGalleryView.astro";
import { DebugConsole } from "../utils/DebugConsole";

const { frontmatter } = Astro.props;
const album = frontmatter?.album;
const dynamicPhotoLimit = SkiCycleRunConfig.photoApi.dynamicPhotos;
if (!album) throw new Error("PhotoLayout requires frontmatter.album to be set");

const photos = await getAlbumPhotos(album);
if (!photos || photos.length === 0) {
  // Render a friendly fallback instead of throwing to avoid breaking the page
  DebugConsole.warn(`Album \"${album}\" returned no photos`);
}
---

<article
  class="photo-layout"
  data-album={album}
  data-dynamic-photo-limit={dynamicPhotoLimit}
>
  <header class="photo-layout-header mb-2">
    {
      frontmatter.title && (
        <h1 class="text-3xl font-bold">{frontmatter.title}</h1>
      )
    }
    {
      frontmatter.description && (
        <p class="text-skin-muted mt-2">{frontmatter.description}</p>
      )
    }
  </header>

  <div class="photo-controls-wrap relative mb-0">
    <!-- Click hint tooltip - positioned on same line as radio controls, centered -->
    <div
      id="click-hint"
      class="absolute top-1/2 -translate-y-1/2 left-1/2 -translate-x-1/2 transition-opacity duration-500 animate-bounce"
      style="z-index: 30; pointer-events: none;"
    >
      <div class="click-hint-pill">👇 Tap photo</div>
    </div>

    <nav
      class="photo-view-nav flex justify-end"
      aria-label="Photo view selector"
    >
      <div class="photo-view-nav-group flex gap-4">
        <label class="cursor-pointer">
          <input type="radio" name="photo-view" value="hero" /> Hero
        </label>
        <label class="cursor-pointer">
          <input type="radio" name="photo-view" value="gallery" checked /> Gallery
        </label>
        <label class="cursor-pointer">
          <input type="radio" name="photo-view" value="carousel" /> Carousel
        </label>
      </div>
    </nav>
  </div>

  <div class="photo-stage relative mt-1">
    <section class="photo-view relative">
      <div id="photo-hero" style="display:none">
        <MDXHeroView photos={photos} frontmatter={frontmatter} />
      </div>
      <div id="photo-gallery">
        <MDXGalleryView photos={photos} frontmatter={frontmatter} />
      </div>
      <div id="photo-carousel" style="display:none">
        <MDXCarousel3 photos={photos} />
      </div>
    </section>
  </div>

  <div
    class="photo-style-controls mt-4 flex flex-wrap items-center justify-center gap-3 text-sm"
  >
    <label for="lora-style" class="font-medium">Art Style:</label>
    <select
      id="lora-style"
      class="px-3 py-1.5 rounded border border-skin-line bg-skin-fill text-skin-base cursor-pointer"
    >
      <option value="random" selected>Random Mix</option>
      <option value="Afremov">Afremov</option>
      <option value="Gorillaz">Gorillaz</option>
      <option value="Origami">Origami</option>
      <option value="PencilDrawing">Pencil Drawing</option>
      <option value="FractalGeometry">Fractal Geometry</option>
    </select>
    <span class="text-skin-muted">·</span>
    <label class="cursor-pointer flex items-center gap-2">
      <input type="checkbox" id="use-dynamic" class="cursor-pointer" />
      <span class="font-medium"
        >Full Album <span class="text-skin-muted italic">(slower)</span></span
      >
    </label>
  </div>

  <div id="dynamic-loading" style="display:none" class="dynamic-loading">
    <p>Loading full image library from API...</p>
    <div class="spinner"></div>
  </div>

  <!-- Render page MDX content inside the master layout -->
  <slot />

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const debugEnabled = import.meta.env.PUBLIC_DEBUG_OUTPUT === "true";
      const debugLog = (...args) => {
        if (debugEnabled) console.log("[DEBUG][UI]", ...args);
      };
      const debugWarn = (...args) => {
        if (debugEnabled) console.warn("[DEBUG][WARN]", ...args);
      };
      const debugError = (...args) => {
        if (debugEnabled) console.error("[DEBUG][ERROR]", ...args);
      };

      const radios = Array.from(
        document.querySelectorAll('input[name="photo-view"]'),
      );
      const dynamicCheckbox = document.getElementById(
        "use-dynamic",
      ) as HTMLInputElement | null;
      const loraSelect = document.getElementById(
        "lora-style",
      ) as HTMLSelectElement | null;
      const album = document
        .querySelector(".photo-layout")
        ?.getAttribute("data-album");
      const dynamicPhotoLimit = Number(
        document
          .querySelector(".photo-layout")
          ?.getAttribute("data-dynamic-photo-limit") || "250",
      );
      const loadingEl = document.getElementById("dynamic-loading");
      const clickHint = document.getElementById("click-hint");

      const sections = {
        hero: document.getElementById("photo-hero"),
        gallery: document.getElementById("photo-gallery"),
        carousel: document.getElementById("photo-carousel"),
      };

      // Always start with fast initial mode; full library is explicit opt-in.
      if (dynamicCheckbox) {
        dynamicCheckbox.checked = false;
      }

      // Show the selector hint only once on initial load, then hide after 2 seconds.
      if (clickHint) {
        setTimeout(() => {
          clickHint.style.opacity = "0";
          setTimeout(() => {
            clickHint.style.display = "none";
          }, 500);
        }, 2000);
      }

      let dynamicPhotosLoaded = false;
      let dynamicPhotos: any[] = [];
      let dynamicPhotosFullSet: any[] = [];
      let staticPhotos: any[] = []; // Store original static photos

      // Get initial static photos from the page (try all views)
      function getStaticPhotos() {
        // Try hero view first
        for (const [viewName, viewDiv] of Object.entries(sections)) {
          if (viewDiv) {
            const scriptTag = viewDiv.querySelector(
              'script[type="application/json"]',
            );
            if (scriptTag) {
              try {
                const photos = JSON.parse(scriptTag.textContent || "[]");
                if (photos.length > 0) {
                  debugLog(
                    `[PhotoLayout] Found ${photos.length} static photos in ${viewName} view`,
                  );
                  return photos;
                }
              } catch (e) {
                debugWarn(
                  `[PhotoLayout] Failed to parse static photos from ${viewName}:`,
                  e,
                );
              }
            }
          }
        }
        debugWarn("[PhotoLayout] No static photos found in any view");
        return [];
      }

      // Filter static photos by art style
      function filterStaticPhotosByStyle(photos, style) {
        debugLog(
          `[PhotoLayout] filterStaticPhotosByStyle called with ${photos.length} photos, style: ${style}`,
        );

        if (style === "random" || !style) {
          debugLog("[PhotoLayout] No filtering - showing all photos (random)");
          return photos;
        }

        const filtered = photos.filter((photo) => {
          // First check for explicit loraStyle property
          let loraStyle =
            photo.loraStyle ||
            photo.lora_style ||
            photo.LoraStyle ||
            photo.style;

          // If no property, extract from filename
          // Format: IMG_####_StyleName_########.webp
          if (!loraStyle && photo.src) {
            const filename = photo.src.split("/").pop(); // Get filename
            const match = filename.match(/_([A-Za-z]+)_\d+\./); // Match _StyleName_digits.
            if (match && match[1]) {
              loraStyle = match[1];
            }
          }

          const matches = loraStyle === style;
          debugLog(
            `[PhotoLayout] Photo: ${photo.src.split("/").pop()}, extracted style: ${loraStyle}, matches ${style}: ${matches}`,
          );
          return matches;
        });

        debugLog(
          `[PhotoLayout] Filtered ${photos.length} photos to ${filtered.length} for style: ${style}`,
        );

        // If filtering resulted in no photos, return all photos instead of empty array
        if (filtered.length === 0) {
          debugWarn(
            `[PhotoLayout] No photos match style "${style}", returning all photos instead`,
          );
          return photos;
        }

        return filtered;
      }

      function parseApiPhotoArray(payload) {
        if (Array.isArray(payload)) return payload;
        if (payload && Array.isArray(payload.photos)) return payload.photos;
        if (payload && Array.isArray(payload.data)) return payload.data;
        if (payload && Array.isArray(payload.items)) return payload.items;
        return [];
      }

      function buildAlbumCandidates(rawAlbum) {
        const base = `${rawAlbum || ""}`.trim();
        if (!base) return [];

        const camelToDash = base.replace(/([a-z0-9])([A-Z])/g, "$1-$2");
        const dashToCamel = base.replace(/-([a-zA-Z0-9])/g, (_, c) =>
          `${c}`.toUpperCase(),
        );

        const candidates = [
          base,
          base.toLowerCase(),
          base.replace(/\s+/g, "-"),
          base.replace(/\s+/g, ""),
          camelToDash,
          camelToDash.toLowerCase(),
          dashToCamel,
          dashToCamel.toLowerCase(),
        ];

        return [...new Set(candidates.filter(Boolean))];
      }

      async function loadDynamicPhotos(loraStyle = "random") {
        if (dynamicPhotosLoaded && dynamicPhotosFullSet.length > 0) {
          dynamicPhotos = filterStaticPhotosByStyle(
            dynamicPhotosFullSet,
            loraStyle,
          );
          debugLog(
            `[PhotoLayout] Using cached dynamic photos for style: ${loraStyle}`,
          );
          return dynamicPhotos;
        }

        if (!album) return [];

        try {
          if (loadingEl) loadingEl.style.display = "flex";

          const baseUrl =
            (window as typeof window & { PUBLIC_SKICYCLERUN_API?: string })
              .PUBLIC_SKICYCLERUN_API || "https://api.skicyclerun.com/v2/";
          const candidates = buildAlbumCandidates(album);
          let photoArray: any[] = [];
          let usedAlbum = "";

          for (const candidate of candidates) {
            // Full library mode must use the full album endpoint.
            const photoURL = `${baseUrl}getphotos?album=${encodeURIComponent(candidate)}`;
            debugLog(
              `[PhotoLayout] Fetching full library from API: ${photoURL}`,
            );

            const res = await fetch(photoURL);
            const data = await res.json();
            const parsed = parseApiPhotoArray(data);

            if (parsed.length > 0) {
              photoArray = parsed;
              usedAlbum = candidate;
              break;
            }
          }

          // Backward-compatible fallback for environments that do not expose getphotos.
          if (photoArray.length === 0) {
            for (const candidate of candidates) {
              const fallbackURL = `${baseUrl}getphotosrandom?bucketName=skicyclerun.lib&albumPath=albums/${encodeURIComponent(candidate)}/&numPhotos=${dynamicPhotoLimit}`;
              debugWarn(
                `[PhotoLayout] Full-library endpoint returned empty, trying fallback: ${fallbackURL}`,
              );
              const res = await fetch(fallbackURL);
              const data = await res.json();
              const parsed = parseApiPhotoArray(data);
              if (parsed.length > 0) {
                photoArray = parsed;
                usedAlbum = candidate;
                break;
              }
            }
          }

          if (photoArray.length > 0) {
            const normalized = photoArray
              .map((p, i) => {
                const src =
                  typeof p === "string"
                    ? p
                    : p?.src || p?.url || p?.image || p?.imageUrl;
                if (!src) return null;
                return {
                  src,
                  altText: p?.altText || `Photo ${i + 1}`,
                  alt: p?.alt,
                  loraStyle: p?.loraStyle || p?.lora_style || p?.style,
                  sourceType: "remote",
                };
              })
              .filter(Boolean);

            dynamicPhotosFullSet =
              dynamicPhotoLimit > 0
                ? normalized.slice(0, dynamicPhotoLimit)
                : normalized;

            dynamicPhotos = filterStaticPhotosByStyle(
              dynamicPhotosFullSet,
              loraStyle,
            );
            dynamicPhotosLoaded = true;
            debugLog(
              `✅ Loaded ${dynamicPhotosFullSet.length} full-library photos from API; filtered to ${dynamicPhotos.length} for style: ${loraStyle}`,
            );
            if (usedAlbum && usedAlbum !== `${album}`) {
              debugWarn(
                `[PhotoLayout] Full library album "${album}" resolved as "${usedAlbum}"`,
              );
            }
          } else {
            debugWarn(
              `[PhotoLayout] No full-library photos returned from API for album "${album}"`,
            );
          }

          if (loadingEl) loadingEl.style.display = "none";
          return dynamicPhotos;
        } catch (error) {
          debugError("Failed to load dynamic photos:", error);
          if (loadingEl) {
            loadingEl.innerHTML =
              '<p class="error">Failed to load photos from API</p>';
            setTimeout(() => {
              if (loadingEl) loadingEl.style.display = "none";
            }, 3000);
          }
          return [];
        }
      }

      function updateViewContent(photos) {
        debugLog(
          `[PhotoLayout] Updating view content with ${photos.length} photos`,
        );

        // Update Hero view
        const heroContainer = sections.hero;
        if (heroContainer && photos.length > 0) {
          // Update the JSON data that Hero view uses for navigation
          const heroJsonScript = heroContainer.querySelector(
            'script[type="application/json"]#hero-photos',
          );
          if (heroJsonScript) {
            heroJsonScript.textContent = JSON.stringify(photos).replace(
              /</g,
              "\\u003c",
            );
            debugLog("[PhotoLayout] Hero JSON updated");
          }

          const heroImg = heroContainer.querySelector(
            "img",
          ) as HTMLImageElement | null;
          if (heroImg && photos[0]) {
            heroImg.src = photos[0].src;
            heroImg.alt = photos[0].altText || "Photo";
            heroImg.dataset.currentIndex = "0"; // Reset to first image
            debugLog("[PhotoLayout] Hero image updated to:", photos[0].src);
          }

          // Remove old event listeners by cloning the image element
          if (heroImg) {
            const heroFigure = heroContainer.querySelector(
              "figure[data-photos-json]",
            ) as HTMLElement | null;
            if (heroFigure) {
              delete heroFigure.dataset.heroInitialized;

              // Reset counter to 1/N before cloning
              const counterEl = heroFigure.querySelector(
                "#hero-counter",
              ) as HTMLElement | null;
              if (counterEl) {
                counterEl.textContent =
                  photos.length > 1 ? `1 / ${photos.length}` : "";
              }

              // Clone image to remove all event listeners
              const newImg = heroImg.cloneNode(true) as HTMLImageElement;
              heroImg.parentNode?.replaceChild(newImg, heroImg);

              // Re-attach click handler with new photos array
              newImg.addEventListener("click", () => {
                let idx = Number(newImg.dataset.currentIndex) || 0;
                idx = (idx + 1) % photos.length;
                newImg.dataset.currentIndex = String(idx);
                const p = photos[idx];
                if (p) {
                  newImg.style.transform = "scale(0.93)";
                  newImg.style.opacity = "0.7";
                  setTimeout(() => {
                    newImg.src = p.src;
                    newImg.alt = p.altText || `Photo ${idx + 1}`;
                    newImg.style.transform = "";
                    newImg.style.opacity = "";
                    if (counterEl && photos.length > 1) {
                      counterEl.textContent = `${idx + 1} / ${photos.length}`;
                    }
                    debugLog(
                      `[PhotoLayout] Hero clicked - showing photo ${idx + 1}/${photos.length}`,
                    );
                  }, 120);
                }
              });
              debugLog(
                "[PhotoLayout] Hero click handler reattached with new photos",
              );
            }
          }
        }

        // Update Gallery view — dispatch event for MDXGalleryView to handle
        const galleryContainer = sections.gallery;
        if (galleryContainer && photos.length > 0) {
          const galleryDiv = galleryContainer.querySelector(".mdx-gallery");
          if (galleryDiv) {
            galleryDiv.dispatchEvent(
              new CustomEvent("gallery-update", {
                detail: { photos },
                bubbles: false,
              }),
            );
            debugLog(
              `[PhotoLayout] Gallery update event dispatched (${photos.length} photos)`,
            );
          }
        }
        // Update Carousel view
        const carouselContainer = sections.carousel;
        if (carouselContainer) {
          const carouselRoot = carouselContainer.querySelector(
            ".carousel-container",
          ) as HTMLElement | null;

          // Update the JSON data for carousel
          const carouselJsonScript = carouselContainer.querySelector(
            'script[type="application/json"]',
          );
          if (carouselJsonScript) {
            carouselJsonScript.textContent = JSON.stringify(photos).replace(
              /</g,
              "\\u003c",
            );
            debugLog("[PhotoLayout] Carousel JSON updated");
          }

          // Find the carousel track and slides
          const track = carouselContainer.querySelector(".carousel-track");
          if (track) {
            // Rebuild slides using clones of existing SSR nodes so Astro-scoped CSS still applies.
            const existingSlides = Array.from(
              track.querySelectorAll(".carousel-slide"),
            );
            const templateSlide = existingSlides[0] || null;

            if (templateSlide) {
              track.replaceChildren();
              photos.forEach((photo, i) => {
                const slide = templateSlide.cloneNode(true);
                if (!(slide instanceof HTMLElement)) return;

                slide.setAttribute("data-src", photo.src);
                const img = slide.querySelector("img");
                if (img) {
                  img.src = photo.src;
                  img.alt = photo.altText || `Photo ${i + 1}`;
                }

                track.appendChild(slide);
              });
            }

            // Reset carousel to first slide and force re-initialize on every data swap.
            if (carouselRoot) {
              delete carouselRoot.dataset.carouselInitialized;

              const intervalId = carouselRoot.dataset.carouselInterval;
              if (intervalId) {
                clearInterval(Number(intervalId));
                delete carouselRoot.dataset.carouselInterval;
              }

              if (track) track.scrollLeft = 0;

              const event = new CustomEvent("reinit-carousel", {
                detail: { containerId: carouselRoot.id },
              });
              document.dispatchEvent(event);
            }

            debugLog(
              `[PhotoLayout] Carousel slides rebuilt with ${photos.length} photos and reinitialized`,
            );
          }
        }
      }

      // Track whether this is the very first update call (page load).
      // On first load all three views already have the correct SSR photos — no
      // updateViewContent call is needed; we only show/hide the right section.
      let isInitialLoad = true;

      async function update() {
        const checked = document.querySelector(
          'input[name="photo-view"]:checked',
        );
        const value = checked ? checked.getAttribute("value") : "gallery";
        const useDynamic = dynamicCheckbox?.checked || false;
        const loraStyle = loraSelect?.value || "random";

        // Always: show/hide the selected view section
        Object.keys(sections).forEach((k) => {
          const el = sections[k];
          if (!el) return;
          el.style.display = k === value ? "" : "none";
        });

        if (isInitialLoad && !useDynamic && loraStyle === "random") {
          // SSR already embedded the correct 16 photos in every view — nothing to do.
          isInitialLoad = false;
          return;
        }
        isInitialLoad = false;

        if (useDynamic) {
          // Full Image Library — load all photos from API
          const photos = await loadDynamicPhotos(loraStyle);
          if (photos.length > 0) {
            updateViewContent(photos);
          }
        } else {
          // Static photos filtered by art style
          if (staticPhotos.length === 0) {
            staticPhotos = getStaticPhotos();
          }
          const filteredPhotos = filterStaticPhotosByStyle(
            staticPhotos,
            loraStyle,
          );
          if (filteredPhotos.length > 0) {
            updateViewContent(filteredPhotos);
          }
        }
      }

      radios.forEach((r) => r.addEventListener("change", update));
      dynamicCheckbox?.addEventListener("change", update);
      loraSelect?.addEventListener("change", () => update());

      // On load: show the correct default section (gallery). Views are already
      // populated from SSR — no API call needed here.
      update();
    });
  </script>
</article>

<style>
  .photo-layout {
    --photo-frame-max-width: 1024px;
    --photo-frame-radius: clamp(0.9rem, 2.6vw, 1.8rem);
    --photo-frame-aspect: 1 / 1;
    --photo-nav-label-padding: 0.35rem 0.72rem;
    --photo-nav-gap: 0.55rem;
    --photo-stage-shadow: 0 24px 60px rgba(0, 0, 0, 0.22);
    width: min(100%, var(--photo-frame-max-width));
    max-width: var(--photo-frame-max-width);
    margin-left: auto;
    margin-right: auto;
    padding: 0 clamp(0.35rem, 2.4vw, 1.25rem);
    box-sizing: border-box;
  }

  .photo-layout-header {
    max-width: min(100%, var(--photo-frame-max-width));
    margin: 0 auto;
    padding: 0.2rem 0.4rem 0;
    animation: photo-enter-up 420ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }

  .photo-controls-wrap {
    max-width: min(100%, var(--photo-frame-max-width));
    margin: 0 auto;
    animation: photo-enter-up 520ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    animation-delay: 60ms;
  }

  .click-hint-pill {
    color: rgb(var(--color-text-base));
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.45rem 0.8rem;
    border-radius: 9999px;
    white-space: nowrap;
    border: 1px solid rgba(var(--color-border), 0.68);
    background: linear-gradient(
      135deg,
      rgba(var(--color-card), 0.85),
      rgba(var(--color-fill), 0.5)
    );
    backdrop-filter: blur(14px) saturate(130%);
    -webkit-backdrop-filter: blur(14px) saturate(130%);
    box-shadow: 0 10px 34px rgba(0, 0, 0, 0.22);
  }

  .photo-view-nav-group {
    gap: var(--photo-nav-gap);
    padding: 0.34rem;
    border-radius: 999px;
    border: 1px solid rgba(var(--color-border), 0.5);
    background: linear-gradient(
      135deg,
      rgba(var(--color-card), 0.8),
      rgba(var(--color-fill), 0.35)
    );
    backdrop-filter: blur(14px) saturate(130%);
    -webkit-backdrop-filter: blur(14px) saturate(130%);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.24);
  }

  .photo-view-nav-group label {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: var(--photo-nav-label-padding);
    border-radius: 999px;
    color: rgb(var(--color-text-muted));
    font-weight: 600;
    line-height: 1;
    transition:
      color 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.16s ease;
  }

  .photo-view-nav-group label:has(input:checked) {
    color: rgb(var(--color-text-base));
    background: rgba(var(--color-card), 0.95);
    box-shadow:
      inset 0 0 0 1px rgba(var(--color-border), 0.5),
      0 8px 24px rgba(0, 0, 0, 0.2);
  }

  .photo-view-nav-group label:active {
    transform: scale(0.97);
  }

  .photo-view-nav-group input[type="radio"] {
    margin: 0;
    accent-color: rgb(var(--color-accent));
  }

  .photo-stage {
    max-width: min(100%, var(--photo-frame-max-width));
    margin: 0.25rem auto 0;
    animation: photo-enter-up 620ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    animation-delay: 110ms;
  }

  /* Keep selector row visually attached to the photo frame */
  .photo-layout nav[aria-label="Photo view selector"] {
    margin-bottom: 0.25rem;
    line-height: 1.1;
  }

  .photo-layout nav[aria-label="Photo view selector"] .flex {
    margin: 0;
    align-items: center;
  }

  /* Keep the photo view area a fixed viewport so hero/gallery/carousel share same box */
  .photo-view {
    margin-top: 0;
    padding-top: 0;
    line-height: 0;
  }

  .photo-view > div {
    --carousel-aspect: var(--photo-frame-aspect);
    width: 100%;
    max-width: var(--photo-frame-max-width);
    margin-left: auto;
    margin-right: auto;
    margin-top: 0;
    aspect-ratio: var(--photo-frame-aspect);
    max-height: min(84svh, 980px);
    background:
      radial-gradient(
        120% 140% at 15% 10%,
        rgba(var(--color-accent), 0.16),
        rgba(var(--color-fill), 0.45) 40%,
        rgba(var(--color-fill), 0.96) 100%
      ),
      rgb(var(--color-fill));
    position: relative;
    overflow: hidden;
    border-radius: var(--photo-frame-radius);
    border: 1px solid rgba(var(--color-border), 0.45);
    box-shadow:
      var(--photo-stage-shadow),
      inset 0 1px 0 rgba(255, 255, 255, 0.16);
  }

  .photo-style-controls {
    max-width: min(100%, var(--photo-frame-max-width));
    margin-left: auto;
    margin-right: auto;
    padding: 0.5rem 0.7rem;
    border-radius: 1rem;
    border: 1px solid rgba(var(--color-border), 0.48);
    background: rgba(var(--color-card), 0.72);
    backdrop-filter: blur(16px) saturate(125%);
